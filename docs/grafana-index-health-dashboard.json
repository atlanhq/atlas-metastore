{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "title": "Index Health Status",
      "description": "1 = healthy (all property keys registered), 0 = unhealthy (missing property keys)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "UNHEALTHY", "color": "red" }, "1": { "text": "HEALTHY", "color": "green" } } }
          ]
        }
      },
      "targets": [
        {
          "expr": "atlas_metastore_atlas_index_health_status{tenant=~\"$tenant\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Missing Core Attributes",
      "description": "Core type attributes missing from mixed index. If > 0, ALL tenants are affected (P0).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "atlas_metastore_atlas_index_health_core_missing_total{tenant=~\"$tenant\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Unhealthy Tenants",
      "description": "Number of tenants with missing mixed index property keys",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(atlas_metastore_atlas_index_health_status{tenant=~\"$tenant\", instance=~\"$instance\"} == 0) or vector(0)",
          "legendFormat": "unhealthy tenants"
        }
      ]
    },
    {
      "title": "Fleet-wide Missing Attributes",
      "description": "Total missing attributes across all tenants",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(atlas_metastore_atlas_index_health_missing_total{source=\"all\", tenant=~\"$tenant\", instance=~\"$instance\"}) or vector(0)",
          "legendFormat": "total missing"
        }
      ]
    },
    {
      "title": "Entity Attributes: Expected vs Indexed vs Missing",
      "description": "Breakdown of entity type attribute index registration",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "missing" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "indexed" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "expected" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "atlas_metastore_atlas_index_health_expected_total{category=\"entity\", tenant=~\"$tenant\", instance=~\"$instance\"}",
          "legendFormat": "expected"
        },
        {
          "expr": "atlas_metastore_atlas_index_health_indexed_total{category=\"entity\", tenant=~\"$tenant\", instance=~\"$instance\"}",
          "legendFormat": "indexed"
        },
        {
          "expr": "atlas_metastore_atlas_index_health_missing_total{category=\"entity\", source=\"all\", tenant=~\"$tenant\", instance=~\"$instance\"}",
          "legendFormat": "missing"
        }
      ]
    },
    {
      "title": "Business Metadata: Expected vs Indexed vs Missing",
      "description": "Breakdown of business metadata attribute index registration",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "missing" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "indexed" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "expected" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "atlas_metastore_atlas_index_health_expected_total{category=\"business_metadata\", tenant=~\"$tenant\", instance=~\"$instance\"}",
          "legendFormat": "expected"
        },
        {
          "expr": "atlas_metastore_atlas_index_health_indexed_total{category=\"business_metadata\", tenant=~\"$tenant\", instance=~\"$instance\"}",
          "legendFormat": "indexed"
        },
        {
          "expr": "atlas_metastore_atlas_index_health_missing_total{category=\"business_metadata\", source=\"all\", tenant=~\"$tenant\", instance=~\"$instance\"}",
          "legendFormat": "missing"
        }
      ]
    },
    {
      "title": "Missing Attributes: Core vs Custom",
      "description": "Core = from addons/models (affects all tenants). Custom = tenant-specific types.",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "atlas_metastore_atlas_index_health_missing_total{category=\"entity\", source=\"core\", tenant=~\"$tenant\", instance=~\"$instance\"}",
          "legendFormat": "core"
        },
        {
          "expr": "atlas_metastore_atlas_index_health_missing_total{category=\"entity\", source=\"custom\", tenant=~\"$tenant\", instance=~\"$instance\"}",
          "legendFormat": "custom"
        }
      ]
    },
    {
      "title": "Missing Attributes by Entity Type",
      "description": "Which entity types have missing property keys (only types with missing attrs shown)",
      "type": "table",
      "gridPos": { "h": 6, "w": 10, "x": 6, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "custom": {
            "displayMode": "color-background"
          }
        }
      },
      "transformations": [
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "Value", "desc": true }] }
        }
      ],
      "targets": [
        {
          "expr": "atlas_metastore_atlas_index_health_type_missing{tenant=~\"$tenant\", instance=~\"$instance\"} > 0",
          "format": "table",
          "legendFormat": "{{typeName}}"
        }
      ]
    },
    {
      "title": "Unhealthy Tenants List",
      "description": "All tenants where atlas_metastore_atlas_index_health_status = 0",
      "type": "table",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 10 },
      "targets": [
        {
          "expr": "atlas_metastore_atlas_index_health_status == 0",
          "format": "table",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Index Health Status Over Time",
      "description": "Track health status changes across pod restarts and Cedar pushes",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "custom": {
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "atlas_metastore_atlas_index_health_status{tenant=~\"$tenant\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Missing Attributes Over Time",
      "description": "Track missing attribute count — should trend to zero after self-healing deploys",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "custom": {
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "sum(atlas_metastore_atlas_index_health_missing_total{source=\"all\", tenant=~\"$tenant\", instance=~\"$instance\"}) by (tenant, instance)",
          "legendFormat": "{{instance}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["atlas", "metastore", "index-health", "cassandra-es-sync"],
