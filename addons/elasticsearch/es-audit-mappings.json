{
  "mappings": {
    "properties": {
      "entityQualifiedName": {
        "type": "keyword"
      },
      "entityId": {
        "type": "keyword"
      },
      "typeName": {
        "type": "keyword"
      },
      "created": {
        "type": "date"
      },
      "timestamp": {
        "type": "date"
      },
      "action": {
        "type": "keyword"
      },
      "detail": {
        "type": "nested"
      },
      "user": {
        "type": "keyword"
      },
      "eventKey": {
        "type": "keyword"
      }
    },
    "dynamic_templates": [
      {
        "suppress_detail_all": {
          "path_match": "detail.*",
          "match_mapping_type": "*",
          "mapping": { "enabled": false }
        }
      },
      {
        "atlan_headers_as_keyword": {
          "path_match": "headers.x-atlan-*",
          "mapping":    { "type": "keyword" }
        }
      }
    ],
    "date_detection": false,
    "numeric_detection": false
  }
}